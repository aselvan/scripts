{
  "manifest_version": 3,
  "name": "LinkedIn Extension Blocker",
  "version": "1.2.1",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "description": "Blocks LinkedIn from scanning your browser extensions",
  "author": "Arul Selvan",
  "homepage_url": "https://www.selvansoft.com",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["src/inject.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/patch.js"],
      "matches": ["*://*.linkedin.com/*"]
    }
  ]
}
